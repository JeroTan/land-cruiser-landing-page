{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "land-cruiser-landing-page",
  "main": "src/cloudflare/worker.ts",
	"compatibility_date": "2025-09-15",
	"compatibility_flags": [
		"nodejs_compat",
		// "nodejs_compat_v2",
		"global_fetch_strictly_public",
	],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}