{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "land-cruiser-landing-page",
  "main": "src/cloudflare/worker.ts",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat_v2"],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}